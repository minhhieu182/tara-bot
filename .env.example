# Required — get from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Required — https://aistudio.google.com/app/apikey
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required — https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here

# Your Telegram user ID (see DEPLOY.md for how to get it)
ALLOWED_USER_ID=your_telegram_user_id

# Affiliate (optional — injects link into flight/search results)
AFFILIATE_TEMPLATE=shopee.vn/{product_id}?af_id=your_affiliate_id
